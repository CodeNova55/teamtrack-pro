# ── Supabase ─────────────────────────────────────────────────────────
# Found in: Supabase Dashboard → Project Settings → API
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# ── Mock mode ────────────────────────────────────────────────────────
# Set to "true" for local dev with mock data, "false" for real Supabase
VITE_USE_MOCK=false

# ── Claude AI (optional) ─────────────────────────────────────────────
# Required only if the Claude AI chat feature is enabled
# Found in: https://console.anthropic.com/
VITE_ANTHROPIC_API_KEY=your_anthropic_api_key_here
